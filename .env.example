# Database
DATABASE_URL=postgresql://pai_user:pai_password@localhost:5432/pai_db

# Runtime
NODE_ENV=development

# Wikimedia APIs are public — no key required
WIKIPEDIA_API_BASE=https://en.wikipedia.org/api/rest_v1
WIKIMEDIA_PAGEVIEWS_BASE=https://wikimedia.org/api/rest_v1
WIKIDATA_SPARQL_BASE=https://query.wikidata.org
WIKIDATA_REST_BASE=https://www.wikidata.org/w/api.php

# Set a descriptive User-Agent — required by Wikimedia policy to avoid throttling
# Format: AppName/Version (contact@example.com)
WIKIMEDIA_USER_AGENT=PopularityIndex/0.1.0 (contact@example.com)

# Provider concurrency settings
PROVIDER_CONCURRENCY=3
PROVIDER_RETRY_COUNT=3
PROVIDER_RETRY_DELAY_MS=1000

# Set to true to skip database connection check (used in CI builds)
SKIP_DB_CHECK=false
