{
  "name": "popularity-index",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @pai/web dev",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "db:migrate": "pnpm --filter @pai/db migrate",
    "db:seed": "pnpm --filter @pai/db seed",
    "ingest:wikipedia": "pnpm --filter @pai/worker ingest:wikipedia",
    "score:calculate": "pnpm --filter @pai/worker score:calculate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
